# Kup 환경변수 템플릿 — 복사: `cp .env.example .env.local`
# ⚠️ .env.local / .env.* 는 .gitignore 됨. 실제 키는 절대 커밋 금지(SPEC 2.2).
# worktree마다 독립 → 각 머신/worktree에서 자체 .env.local 작성.

# ── 프론트+API (Vercel, NEXT_PUBLIC_* 는 브라우저 노출) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── 서버/워커 전용 (브라우저 노출 금지) ─────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # RLS 우회 — 워커 전용

# 워커(Railway) — BullMQ/Upstash Redis. 없으면 워커 기동 시 에러(스캐폴드 단계엔 미설정 가능)
REDIS_URL=rediss://default:<token>@<host>:<port>

# IG 토큰 봉인 대칭키(libsodium). DB 밖 보관.
TOKEN_ENCRYPTION_KEY=

# ── Meta(인스타) 앱 — 앱 전역 자격증명(서비스당 1세트) ──────────────────
# ⚠️ 사용자별 IG 액세스 토큰/IG user id 는 여기 두지 않음.
#    OAuth로 받아 DB(ig_tokens.access_token_enc 암호화 / channels.ig_user_id)에 저장(데이터모델 §2.2).
IG_APP_ID=
IG_APP_SECRET=
IG_OAUTH_REDIRECT_URI=http://localhost:3000/api/ig/callback
IG_WEBHOOK_VERIFY_TOKEN=          # 웹훅 등록 시 입력할 임의 문자열(PoC VERIFY_TOKEN)
# [로컬 개발용·선택] OAuth 전 직접 토큰 테스트:
# DEV_IG_USER_ID=
# DEV_IG_ACCESS_TOKEN=

# LLM (Task 4/5 라우팅 — 없으면 mock으로 구조만)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# 관측 (Task 3은 스텁. DSN 없으면 콘솔 no-op)
SENTRY_DSN=
