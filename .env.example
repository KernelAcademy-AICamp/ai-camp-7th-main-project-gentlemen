# Kup 환경변수 템플릿 — 복사: `cp .env.example .env.local`
# ⚠️ .env.local / .env.* 는 .gitignore 됨. 실제 키 값은 절대 커밋 금지.
#    이 파일엔 "빈 값/플레이스홀더"만 둔다(시크릿 X).
#
# 현재 단계 = "화면 먼저"(워크스페이스 데이터는 로컬 파일DB .data, 로그인만 Supabase).
# 아래 ①②만 채우면 로컬에서 로그인+워크스페이스가 돈다. ③④는 개인/나중.

# ── ① 로컬 Supabase (로그인) — Docker 필요 ────────────────────────────
# 팀원: Docker 실행 → `npx supabase start` → 출력된 URL/키를 그대로 붙여넣기.
#       키는 로컬 표준 기본값이라 팀 전체 동일(비밀 아님). 마이그레이션은 자동 적용됨.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # ← `supabase start` 출력의 anon key
SUPABASE_SERVICE_ROLE_KEY=            # ← `supabase start` 출력의 service_role key

# ── ② 구글 로그인 (선택) ──────────────────────────────────────────────
# supabase/config.toml 이 이 두 값을 참조. 팀 공용 1세트를 공유받아 입력(개별 발급 불필요).
# 비우면 구글 버튼만 안 되고 이메일/비번 로그인은 정상 동작.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ③ Claude(Anthropic) — 개인별(각자 자기 키) ───────────────────────
# 없으면 AI 생성이 템플릿(mock)으로 자동 폴백 → 화면은 다 돌아감.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── ④ 나중/선택 (지금 단계엔 불필요) ─────────────────────────────────
# 실제 인스타 발행 워커·연동 단계에서 필요. 사용자별 IG 토큰은 env가 아니라
# 워크스페이스 UI(연동 인스타 계정)에서 계정별로 입력한다.
# REDIS_URL=                          # BullMQ 워커(예약/cron)
# PUBLIC_BASE_URL=                    # 인스타 발행용 공개 https 주소(로컬은 ngrok 등)
# IG_GRAPH_VERSION=v21.0              # Meta Graph API 버전(기본값)
# IG_APP_ID=                          # Meta 앱 전역 자격증명(서비스당 1세트)
# IG_APP_SECRET=
# TOKEN_ENCRYPTION_KEY=               # IG 토큰 봉인 대칭키
# SENTRY_DSN=                         # 관측(현재 스텁)
